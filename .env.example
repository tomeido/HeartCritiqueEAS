# ── LLM 파이프라인 ──────────────────────────────────────────────────────────
# groq (기본) 또는 gemini
LLM_PROVIDER=groq

# Groq 파이프라인 (LLM_PROVIDER=groq 일 때)
GROQ_API_KEY=
TAVILY_API_KEY=

# Gemini 파이프라인 (LLM_PROVIDER=gemini 일 때)
GEMINI_API_KEY=

# 선택: Tavily 도메인 허용 목록 오버라이드 (콤마 구분)
# TAVILY_INCLUDE_DOMAINS=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase 프로젝트 설정 → Settings > API 에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── 에이전트 크립토 키 ────────────────────────────────────────────────────────
# Ethereum 개인키 (Irys 업로드 수수료 지불 + 데이터셋 서명용)
# 0x 접두사 포함 또는 제외 모두 가능
AGENT_PRIVATE_KEY=

# ── Irys / Arweave ───────────────────────────────────────────────────────────
# devnet  = 테스트넷(무료). 업로드 데이터는 "영구가 아님" — 약 60일 후 삭제됨.
#           UI/조회 링크가 자동으로 devnet.irys.xyz + '임시' 라벨로 표시됨.
# mainnet = 진짜 Arweave 영구 보관(소액 ETH 수수료 필요). '영구 박제' 카피는 이 모드 전용.
IRYS_NETWORK=devnet

# ── 앱 설정 ──────────────────────────────────────────────────────────────────
# 공론화 임계값: 이 표 수에 도달하면 Arweave 박제 트리거 (정적 fallback)
VOTE_THRESHOLD=3

# 동적 임계값: 활성 투표자 수에 따라 자동 스케일 (선택)
# DYNAMIC_THRESHOLD=true
# MIN_VOTE_THRESHOLD=3
# MAX_VOTE_THRESHOLD=12
# VOTERS_PER_VOTE=30
# ACTIVE_WINDOW_DAYS=7

# ── 자동 사냥꾼 (AI Hunter) ──────────────────────────────────────────────────
# 사용자 조작 없이 일정 간격으로 새 스토리를 자동 생성
AUTO_HUNT_ENABLED=true
AUTO_HUNT_INTERVAL_SEC=21600     # 6시간 (4글/일)
AUTO_HUNT_MAX_PENDING=30         # 미박제 글 누적 한계 - 도달 시 일시 정지
AUTO_HUNT_CATEGORY_ROTATE=true   # kindness/critique 교대로

# ── 오래된 글 자동 정리 (Cleanup) ────────────────────────────────────────────
# 투표로 선택받지 못한 오래된 미박제 글을 주기적으로 삭제(DB 무한 누적 방지).
# 박제된 글(Arweave Tx 있음)·투표받은 후보(0표 초과)는 절대 삭제하지 않는다.
STORY_CLEANUP_ENABLED=true
STORY_CLEANUP_AGE_DAYS=14         # 생성 후 이 일수 지난 글만 대상
STORY_CLEANUP_MAX_VOTES=0        # 이 표 수 이하만 삭제 (0 = 한 표도 없는 글만)
# STORY_CLEANUP_INTERVAL_SEC=21600   # 정리 주기 (기본 6시간)
# STORY_CLEANUP_BATCH=200            # .in_() URL 한도 방지용 삭제 배치 크기

# ── 적합성 게이트 (Relevance Gate) ───────────────────────────────────────────
# 검색 결과에 진짜 해당 카테고리 글(미담/기업 비위)이 없으면 LLM 이 NO_FIT 을 내고,
# 쿼리를 바꿔 제한 재시도한다. 모두 실패하면 박제하지 않고 503(수동)/스킵(헌터).
RELEVANCE_GATE_ENABLED=true
# 최대 시도(=쿼리) 수. 2 = 한 번 재시도(단일 generate 의 Groq 토큰을 12000 TPM 아래로 유지).
# 시도마다 Groq 1회 + Tavily 1~2회(검색 폴백), 성공 시 Tavily 1회 더(격차 탐지). 늘리면
# 적합성↑·호출/지연↑·self-429 위험↑.
RELEVANCE_MAX_ATTEMPTS=2

# ── 출처 추적기 (Tracker) ────────────────────────────────────────────────────
# 박제된 글의 출처가 사라지는지 주기적으로 확인 + 박제 실패 글 자동 재시도(sweeper)
TRACKER_ENABLED=true
CHECK_INTERVAL_SEC=300            # 5분 (루프 1회 주기; 실제 글별 주기는 아래 적응형 스케줄)
CHECK_BATCH_SIZE=15
# 적응형 재검사 주기(migrations/006 적용 시): 신규일수록 자주, 안정적이면 드물게.
# TRACK_LIVE_MIN_SEC=1800          # 첫 live/신규 글 (30분)
# TRACK_LIVE_MAX_SEC=604800        # 오래 살아남은 글 상한 (7일)
# TRACK_SOFT_SEC=3600              # soft 삭제/차단 재확인 (1시간)
# TRACK_ERR_BASE_SEC=600           # 에러 지수 백오프 기준 (10분)
# TRACK_ERR_MAX_SEC=86400          # 에러 백오프 상한 (24시간)

# ── 선제 수집기 (Collector) ──────────────────────────────────────────────────
# 검색은 '이미 삭제된 글'을 못 가져온다 → 살아있을 때 RSS 로 화제글을 미리 잡아 비공개로
# 보관(본문+해시)하고 tracker 엔진으로 삭제를 감시. ⚠️ migrations/006 적용 후 켤 것.
# captured_posts 는 비공개 보관이며, 공개/박제하려면 PII 마스킹·사인 배제 등 가드레일 필요.
COLLECTOR_ENABLED=false           # 기본 꺼짐(외부 폴링) — 마이그레이션 후 명시적으로 true
# COLLECTOR_INTERVAL_SEC=600         # 피드 폴링 주기 (10분)
# COLLECTOR_MAX_CAPTURE_PER_CYCLE=20 # 한 주기당 새 본문 GET 상한(정중함/백프레셔)
# COLLECTOR_RECHECK_BATCH=15         # 한 주기당 captured 재검사 건수
# COLLECTOR_FEED_ITEMS=30            # 피드당 상위 N개 항목만
# COLLECTOR_JITTER_LO=1.5            # 요청 사이 랜덤 지연 하한(초)
# COLLECTOR_JITTER_HI=4.0            # 요청 사이 랜덤 지연 상한(초)

# ── Wayback 위임 박제 (Save Page Now 2) ──────────────────────────────────────
# 원본 삭제 대비 중립 외부 스냅샷을 Internet Archive 에 위임(직접 스크래핑/탐지 회피 +
# 법정 인정 타임스탬프 증거). ⚠️ migrations/007 적용 후 켤 것. tracker 루프가 큐를 처리하므로
# TRACKER_ENABLED=true 필요. IA 키 없이 켜면 availability(기존 스냅샷 조회)만 동작.
WAYBACK_ENABLED=false
# IA S3 키 (https://archive.org/account/s3.php 에서 발급) — 새 스냅샷 제출(save)에 필요
IA_ACCESS_KEY=
IA_SECRET_KEY=
# WAYBACK_SUBMIT_PER_CYCLE=4         # 주기당 save 제출 상한(일일 한도 보호)
# WAYBACK_POLL_PER_CYCLE=10          # 주기당 pending 상태 폴링 수(무료)
# WAYBACK_MAX_ATTEMPTS=3             # save 재시도 한도(초과 시 error)
# WAYBACK_POLL_BACKOFF_SEC=120       # pending 재폴링 간격
# WAYBACK_IF_NOT_ARCHIVED_SEC=2592000  # 이 기간 내 기박제면 재캡처 생략(쿼터 절약, 30일)
# 박제 실패 재시도(sweeper) 백오프
# ARCHIVE_RETRY_BASE_SEC=300       # 1차 재시도 대기 (이후 지수 증가)
# ARCHIVE_RETRY_MAX_SEC=21600      # 재시도 간격 상한 (6시간)
# ARCHIVE_RETRY_MAX_ATTEMPTS=10    # 이 횟수 넘으면 영구 실패로 표시(last_archive_error)

# ── 생성 엔드포인트 레이트리밋 (비용 폭탄/DoS 방어) ──────────────────────────
# /api/story 와 A2A message/send 에 적용. 무인증 무제한 호출로 유료 LLM·Tavily
# 크레딧이 소진되는 것을 막는다. (단일 프로세스 전제 — 멀티워커면 Redis 필요)
STORY_RATELIMIT_ENABLED=true
STORY_RATELIMIT_PER_IP=5          # IP당 윈도우 내 생성 횟수
STORY_RATELIMIT_GLOBAL=20         # 전역 윈도우 내 생성 횟수
STORY_RATELIMIT_WINDOW_SEC=600    # 윈도우 길이(10분)
STORY_MAX_PENDING=50             # 미박제 글 전역 상한 (적재 폭주 차단)
RECHECK_RATELIMIT_PER_IP=20      # /api/recheck IP당 윈도우 내 호출 (SSRF 트리거 남용 방지)

# ── 로깅 ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                 # DEBUG/INFO/WARNING/ERROR (기본 INFO)

# ── 격차 탐지 ────────────────────────────────────────────────────────────────
# 커뮤니티 vs 언론 보도 격차 측정 (Tavily 추가 호출 발생)
GAP_DETECTION_ENABLED=true

# 외부 접근 URL (리버스 프록시 사용 시 설정)
# PUBLIC_URL=https://your-domain.com
