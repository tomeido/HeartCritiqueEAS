{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/.well-known/agent-card.json", "destination": "/api/index" },
    { "source": "/.well-known/agent.json", "destination": "/api/index" },
    { "source": "/", "destination": "/api/index" }
  ]
}
